# ──────────────────────────────────────────────
# DevOps Playground – Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and update the values

# Server
PORT=3000
NODE_ENV=development

# Database (use DB_HOST=db when running with Docker Compose)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devops_playground
DB_USER=postgres
DB_PASSWORD=postgres

# Authentication
JWT_SECRET=change-me-to-a-long-random-string

# App
APP_VERSION=1.0.0

